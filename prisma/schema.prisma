// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "sqlite"
  url      = "file:dev.sqlite"
}

model Session {
  id            String    @id
  shop          String
  state         String
  isOnline      Boolean   @default(false)
  scope         String?
  expires       DateTime?
  accessToken   String
  userId        BigInt?
  firstName     String?
  lastName      String?
  email         String?
  accountOwner  Boolean   @default(false)
  locale        String?
  collaborator  Boolean?  @default(false)
  emailVerified Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model ImportJob {
  id            String    @id @default(uuid())
  shopId        String
  status        String    @default("pending") // pending/processing/completed/failed/partial
  fileUrl       String
  totalRows     Int       @default(0)
  processedRows Int       @default(0)
  errorCount    Int       @default(0)
  warningCount  Int       @default(0)
  startedAt     DateTime?
  completedAt   DateTime?
  options       String    // Stringified JSON
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model ExportJob {
  id          String    @id @default(uuid())
  shopId      String
  status      String    @default("pending")
  format      String    @default("xlsx") // xlsx/csv
  fileUrl     String?
  itemCount   Int       @default(0)
  startedAt   DateTime?
  completedAt DateTime?
  filters     String    // Stringified JSON
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model JobLog {
  id          String    @id @default(uuid())
  jobId       String
  jobType     String    // "import" | "export"
  rowNumber   Int?
  level       String    // "info" | "warning" | "error"
  message     String
  rawRowData  String?   // Stringified JSON
  createdAt   DateTime  @default(now())
}
